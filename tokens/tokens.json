{
  "$schema": "SVRN Design System tokens",
  "color": {
    "bg": "#1F1F1F",
    "bgElevated": "#2A2A2A",
    "bgSubtle": "#353535",
    "bgInset": "#171717",
    "border": "#3A3A3A",
    "borderSubtle": "#2F2F2F",
    "borderStrong": "#454545",
    "fg": "#ECE5CB",
    "fgWhite": "rgba(255, 255, 255, 0.95)",
    "fgMuted": "rgba(255, 255, 255, 0.75)",
    "fgSubtle": "rgba(255, 255, 255, 0.55)",
    "fgFaint": "rgba(255, 255, 255, 0.40)",
    "fgQuiet": "rgba(255, 255, 255, 0.25)",
    "accent": "#671F1F",
    "accentBright": "#D85050",
    "accentHover": "#7A2828",
    "accentFill": "rgba(103, 31, 31, 0.15)"
  },
  "shadow": {
    "card": "0 4px 20px -4px rgba(0, 0, 0, 0.50), 0 1px 4px -1px rgba(0, 0, 0, 0.30)",
    "hover": "0 8px 32px -6px rgba(0, 0, 0, 0.60), 0 2px 6px -2px rgba(0, 0, 0, 0.35)",
    "inset": "inset 0 1px 0 rgba(255, 255, 255, 0.03)",
    "display": "0 1px 3px rgba(0, 0, 0, 0.3)"
  },
  "radius": {
    "sm": "4px",
    "md": "6px",
    "lg": "8px",
    "xl": "12px"
  },
  "motion": {
    "ease": "150ms ease",
    "easePage": "300ms ease-out",
    "easeMacro": "600ms ease-in-out"
  },
  "font": {
    "display": "'Fraunces', Georgia, serif",
    "sans": "'Inter', system-ui, -apple-system, sans-serif",
    "mono": "'JetBrains Mono', 'SF Mono', Monaco, monospace"
  },
  "weight": {
    "display": 400,
    "body": 400,
    "medium": 500,
    "strong": 600
  },
  "size": {
    "hero": "clamp(56px, 7vw, 84px)",
    "section": "clamp(36px, 4vw, 44px)",
    "page": "clamp(28px, 3vw, 36px)",
    "lead": "16px",
    "body": "14px",
    "meta": "13px",
    "kicker": "11px"
  },
  "tracking": {
    "display": "-0.025em",
    "body": "-0.005em",
    "kicker": "0.18em"
  }
}
